# Jupyter checkpoints — auto-generated when you run cells, not your work
.ipynb_checkpoints/

# Chart images — generated by the notebook, not source files
*.png

# Python cache — bytecode files Python creates for speed, not needed in git
__pycache__/
*.pyc

# Virtual environments — huge, reproducible from requirements, never commit
.venv/
venv/

# OS files
.DS_Store
Thumbs.db
